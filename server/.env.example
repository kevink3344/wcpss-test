# Local development — uses SQLite (no DB server needed)
DB_CLIENT=better-sqlite3

# Production — uncomment and set for Azure SQL
# DB_CLIENT=mssql
# Azure SQL connection string
# Standard port (1433): Server=your-server.database.windows.net;Database=your-db;User Id=your-user;Password=your-password;Encrypt=true;TrustServerCertificate=false;
# Custom port (e.g. 3342): Server=your-server.database.windows.net,3342;Database=your-db;User Id=your-user;Password=your-password;Encrypt=true;TrustServerCertificate=false;
AZURE_SQL_CONNECTION_STRING=

NODE_ENV=development
PORT=3001
